{
  "buildCommand": null,
  "outputDirectory": "client/build",
  "devCommand": "cd client && npm start",
  "installCommand": "cd client && npm install",
  "framework": "create-react-app",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "github": {
    "silent": true,
    "autoJobCancelation": true
  }
}
